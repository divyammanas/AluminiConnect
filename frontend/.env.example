# Browser-safe configuration only. Never place passwords or private secrets here.
VITE_API_URL=http://127.0.0.1:5002/api/v1
VITE_SOCKET_URL=http://127.0.0.1:5002
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
VITE_RAZORPAY_KEY_ID=rzp_test_replace_me

# Firebase Configuration
VITE_FIREBASE_API_KEY=replace-with-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=replace-with-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=replace-with-firebase-measurement-id
