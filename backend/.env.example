NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://DB_USER:DB_PASSWORD@cluster.example.mongodb.net/alumni_connect

# Generate both values with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Razorpay (use Test Mode while developing)
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace-with-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

# Transactional email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
EMAIL_FROM=AlumniConnect <no-reply@example.com>

# AI resume analysis (optional until the feature is implemented)
OPENAI_API_KEY=replace-with-api-key

